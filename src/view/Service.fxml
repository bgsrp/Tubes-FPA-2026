<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controller.ServiceController">

    <top>
        <Label text="Manajemen Service Laptop"
               style="-fx-font-size:20px; -fx-font-weight:bold;"
               BorderPane.alignment="CENTER"/>
    </top>

    <center>

        <VBox spacing="15">

            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <GridPane hgap="10" vgap="10">

                <Label text="ID Service" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <TextField fx:id="txtId"
                           promptText="Masukkan ID Service"
                           GridPane.rowIndex="0"
                           GridPane.columnIndex="1"/>

                <Label text="ID Laptop" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <TextField fx:id="txtLaptopId"
                           promptText="Masukkan ID Laptop"
                           GridPane.rowIndex="1"
                           GridPane.columnIndex="1"/>

                <Label text="Tanggal Masuk" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <TextField fx:id="txtTanggalMasuk"
                           promptText="yyyy-mm-dd"
                           GridPane.rowIndex="2"
                           GridPane.columnIndex="1"/>

                <Label text="Status" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <TextField fx:id="txtStatus"
                           promptText="Status Service"
                           GridPane.rowIndex="3"
                           GridPane.columnIndex="1"/>

                <Label text="Biaya" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <TextField fx:id="txtBiaya"
                           promptText="Biaya Service"
                           GridPane.rowIndex="4"
                           GridPane.columnIndex="1"/>

            </GridPane>

            <HBox spacing="10">

                <Button text="Tambah"
                        onAction="#addService"/>

                <Button text="Ubah"
                        onAction="#updateService"/>

                <Button text="Hapus"
                        onAction="#deleteService"/>

                <Button text="Clear"
                        onAction="#clearForm"/>

            </HBox>

            <TableView fx:id="serviceTable" prefHeight="350">

                <columns>

                    <TableColumn fx:id="colId"
                                 text="ID Service"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colLaptopId"
                                 text="ID Laptop"
                                 prefWidth="120"/>

                    <TableColumn fx:id="colTanggalMasuk"
                                 text="Tanggal Masuk"
                                 prefWidth="150"/>

                    <TableColumn fx:id="colStatus"
                                 text="Status"
                                 prefWidth="180"/>

                    <TableColumn fx:id="colBiaya"
                                 text="Biaya"
                                 prefWidth="120"/>

                </columns>

            </TableView>

        </VBox>

    </center>

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

</BorderPane>